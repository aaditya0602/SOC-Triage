# Copy to backend/.env (or project root when using docker-compose) and fill in.

# Database — SQLite default for local dev; docker-compose overrides with Postgres
DATABASE_URL=sqlite+aiosqlite:///./soc.db
# DATABASE_URL=postgresql+asyncpg://soc:socpass@localhost:5432/soc

# Auth
JWT_SECRET=generate-a-long-random-string
ANALYST_USERNAME=analyst
ANALYST_PASSWORD=changeme

# Ingest webhook shared secret (Wazuh integration + simulator send this)
INGEST_API_KEY=wazuh-ingest-secret

# Threat intel — leave blank to run in mock mode
VIRUSTOTAL_API_KEY=
OTX_API_KEY=
ABUSEIPDB_API_KEY=
# MOCK_ENRICHMENT=true    # force mock intel even with keys set

# LLM: ollama | anthropic | mock
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
